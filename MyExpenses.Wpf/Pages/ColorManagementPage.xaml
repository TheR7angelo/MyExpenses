<Page x:Class="MyExpenses.Wpf.Pages.ColorManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:margin="clr-namespace:MyExpenses.Wpf.Utils.Margin;assembly=MyExpenses.Wpf.Utils"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:utils="clr-namespace:MyExpenses.Wpf.Utils;assembly=MyExpenses.Wpf.Utils"
      xmlns:viewModel="clr-namespace:MyExpenses.Presentation.ViewModel;assembly=MyExpenses.Presentation"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:behaviors="clr-namespace:MyExpenses.Wpf.Behaviors"
      mc:Ignorable="d"

      Title="ColorManagementPage"

      d:DesignHeight="450"
      d:DesignWidth="800"
      d:DataContext="{d:DesignInstance viewModel:ColorManagementViewModel}"

      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>

    <Grid>

        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">

            <StackPanel margin:PanelExtensions.MarginForAllChildren="5"
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Button Height="56"
                        Width="{Binding Height, RelativeSource={RelativeSource Self}}"
                        Style="{StaticResource MaterialDesignFloatingActionDarkButton}"
                        Command="{Binding ManageColorCommand}">
                    <Button.Content>
                        <materialDesign:PackIcon Kind="Plus"
                                                 Height="{Binding Height, RelativeSource={RelativeSource AncestorType=Button}}"
                                                 Width="{Binding Height, RelativeSource={RelativeSource AncestorType=Button}}">
                        </materialDesign:PackIcon>
                    </Button.Content>
                </Button>

                <ItemsControl ItemsSource="{Binding ColorViewModels}"
                              utils:ItemsControlExtensions.UniformSize="True"
                              utils:ItemsControlExtensions.IsLiveUpdate="True">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel margin:PanelExtensions.MarginForAllChildren="5"
                                       Orientation="Horizontal">
                            </WrapPanel>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <materialDesign:TransitioningContent OpeningEffect="{materialDesign:TransitionEffect Duration=0:0:0.5, Kind=ExpandIn}">

                                <Button Height="{Binding Height, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource Self}}"
                                        Style="{StaticResource MaterialDesignPaperButton}"
                                        Command="{Binding DataContext.ManageColorCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding .}">

                                    <b:Interaction.Behaviors>
                                        <behaviors:DeleteAnimationBehavior IsDeleting="{Binding IsDeleting}"
                                                                       Duration="0:0:1"
                                                                       DeleteCommand="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       DeleteCommandParameter="{Binding .}">
                                        </behaviors:DeleteAnimationBehavior>
                                    </b:Interaction.Behaviors>

                                    <Button.Content>
                                        <StackPanel margin:PanelExtensions.MarginForAllChildren="3"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">

                                            <TextBlock HorizontalAlignment="Left"
                                                       Text="{Binding Name}">
                                            </TextBlock>

                                            <!-- Fill.FallbackValue = Colors.Transparent -->
                                            <Ellipse HorizontalAlignment="Right"
                                                     Stroke="{DynamicResource MaterialDesignBody}" StrokeThickness="1"
                                                     Height="24" Width="{Binding Height, RelativeSource={RelativeSource Self}}"
                                                     Fill="{Binding HexadecimalColorCode, FallbackValue='#00FFFFFF'}">
                                            </Ellipse>

                                        </StackPanel>
                                    </Button.Content>
                                </Button>

                            </materialDesign:TransitioningContent>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Page>