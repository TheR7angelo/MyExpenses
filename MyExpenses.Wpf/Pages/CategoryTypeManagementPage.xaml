<Page x:Class="MyExpenses.Wpf.Pages.CategoryTypeManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:margin="clr-namespace:MyExpenses.Wpf.Utils.Margin;assembly=MyExpenses.Wpf.Utils"
      xmlns:viewModel="clr-namespace:MyExpenses.Presentation.ViewModel;assembly=MyExpenses.Presentation"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:utils="clr-namespace:MyExpenses.Wpf.Utils;assembly=MyExpenses.Wpf.Utils"
      mc:Ignorable="d"

      Title="CategoryTypeManagementPage"

      d:DesignHeight="450"
      d:DesignWidth="800"
      d:DataContext="{d:DesignInstance viewModel:CategoryTypeManagementViewModel}"

      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

        <StackPanel margin:PanelExtensions.MarginForAllChildren="5"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <Button Height="56"
                    Width="{Binding Height, RelativeSource={RelativeSource Self}}"
                    Style="{StaticResource MaterialDesignFloatingActionDarkButton}"
                    Command="{Binding ManageCategoryTypeActionCommand}">

                <Button.Content>
                    <materialDesign:PackIcon Kind="Plus"
                                             Height="{Binding Height, RelativeSource={RelativeSource AncestorType=Button}}"
                                             Width="{Binding Height, RelativeSource={RelativeSource AncestorType=Button}}">
                    </materialDesign:PackIcon>
                </Button.Content>

            </Button>

            <ItemsControl ItemsSource="{Binding CategoryTypeViewModels}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel margin:PanelExtensions.MarginForAllChildren="5"
                                   Orientation="Horizontal">
                        </WrapPanel>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <materialDesign:TransitioningContent OpeningEffect="{materialDesign:TransitionEffect Duration=0:0:0.5, Kind=ExpandIn}">

                            <Button Height="{Binding Height, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource Self}}"
                                    Style="{StaticResource MaterialDesignPaperButton}"
                                    Command="{Binding DataContext.ManageCategoryTypeActionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding .}">

                                <b:Interaction.Behaviors>
                                    <utils:DeleteAnimationBehavior IsDeleting="{Binding IsDeleting}"
                                                                   Duration="0:0:1"
                                                                   DeleteCommand="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                   DeleteCommandParameter="{Binding .}">
                                    </utils:DeleteAnimationBehavior>
                                </b:Interaction.Behaviors>

                                <Button.Content>
                                    <StackPanel margin:PanelExtensions.MarginForAllChildren="3"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">

                                        <TextBlock HorizontalAlignment="Left"
                                                   Text="{Binding Name}">
                                        </TextBlock>

                                        <!-- Fill.FallbackValue = Colors.Transparent -->
                                        <Ellipse HorizontalAlignment="Right"
                                                 Stroke="{DynamicResource MaterialDesignBody}" StrokeThickness="1"
                                                 Height="24" Width="{Binding Height, RelativeSource={RelativeSource Self}}"
                                                 Fill="{Binding Color.HexadecimalColorCode, FallbackValue='#00FFFFFF'}">
                                        </Ellipse>

                                    </StackPanel>
                                </Button.Content>

                            </Button>

                        </materialDesign:TransitioningContent>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </StackPanel>

    </Grid>

</Page>