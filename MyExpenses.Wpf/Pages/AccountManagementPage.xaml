<Page x:Class="MyExpenses.Wpf.Pages.AccountManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MyExpenses.Wpf.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:MyExpenses.Wpf.Converters"
      xmlns:margin="clr-namespace:MyExpenses.Wpf.Utils.Margin;assembly=MyExpenses.Wpf.Utils"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:utils="clr-namespace:MyExpenses.Wpf.Utils;assembly=MyExpenses.Wpf.Utils"
      xmlns:viewModel="clr-namespace:MyExpenses.Presentation.ViewModel;assembly=MyExpenses.Presentation"
      mc:Ignorable="d"

      Title="AccountManagementPage"

      d:DesignHeight="450"
      d:DesignWidth="800"
      d:DataContext="{d:DesignInstance viewModel:AccountManagementViewModel}"

      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Page.Resources>
        <converters:TotalToIconConverter x:Key="TotalToIconConverter" />
    </Page.Resources>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

        <StackPanel margin:PanelExtensions.MarginForAllChildren="5"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <Button Height="56"
                    Width="{Binding Height, RelativeSource={RelativeSource Self}}"
                    Style="{StaticResource MaterialDesignFloatingActionDarkButton}"
                    Command="{Binding DataContext.ManageAccountCommand, RelativeSource={RelativeSource AncestorType=Page}}">
                <Button.Content>
                    <materialDesign:PackIcon Kind="Plus"
                                             Height="{Binding Height, RelativeSource={RelativeSource AncestorType=Button}}"
                                             Width="{Binding Height, RelativeSource={RelativeSource AncestorType=Button}}">
                    </materialDesign:PackIcon>
                </Button.Content>
            </Button>

            <ItemsControl ItemsSource="{Binding TotalByAccounts}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel margin:PanelExtensions.MarginForAllChildren="5"
                                   Orientation="Horizontal">
                        </WrapPanel>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <materialDesign:TransitioningContent OpeningEffect="{materialDesign:TransitionEffect Duration=0:0:0.5, Kind=ExpandIn}">

                            <Button Height="{Binding Height, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource Self}}"
                                Style="{StaticResource MaterialDesignPaperButton}"
                                Command="{Binding DataContext.ManageAccountCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding .}">

                                <b:Interaction.Behaviors>
                                    <utils:DeleteAnimationBehavior IsDeleting="{Binding IsDeleting}"
                                                                   Duration="0:0:1"
                                                                   DeleteCommand="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                   DeleteCommandParameter="{Binding .}">
                                    </utils:DeleteAnimationBehavior>
                                </b:Interaction.Behaviors>

                                <Button.Content>
                                    <StackPanel Orientation="Vertical"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                        <materialDesign:PackIcon
                                            Kind="{Binding Total, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource TotalToIconConverter}}"
                                            Height="96" Width="96"
                                            HorizontalAlignment="Center">
                                        </materialDesign:PackIcon>

                                        <TextBlock Text="{Binding Name}"
                                                   TextAlignment="Center" TextWrapping="Wrap"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                        </TextBlock>

                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">

                                            <Label Content="{Binding Total}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                            </Label>

                                            <Label Content="{Binding Symbol}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                            </Label>

                                        </StackPanel>

                                    </StackPanel>
                                </Button.Content>

                            </Button>

                        </materialDesign:TransitioningContent>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </StackPanel>

    </Grid>

</Page>