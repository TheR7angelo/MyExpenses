<mah:MetroWindow x:Class="MyExpenses.Wpf.Windows.LocationManagementWindows.NominatimSearchWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:wpf="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
                 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                 xmlns:margin="clr-namespace:MyExpenses.Wpf.Utils.Margin;assembly=MyExpenses.Wpf.Utils"
                 xmlns:systems="clr-namespace:Domain.Models.Systems;assembly=MyExpenses.Domain"
                 xmlns:viewModel="clr-namespace:MyExpenses.Presentation.ViewModel;assembly=MyExpenses.Presentation"
                 xmlns:localisations="clr-namespace:MyExpenses.Wpf.Localisations"
                 xmlns:locationResources="clr-namespace:MyExpenses.Presentation.Resources.Resx.LocationResources;assembly=MyExpenses.Presentation"
                 xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:converters="clr-namespace:MyExpenses.Wpf.Converters"
                 mc:Ignorable="d"

                 d:DesignHeight="655"
                 d:DesignWidth="530"
                 d:DataContext="{d:DesignInstance viewModel:NominatimManagementViewModel}"

                 Title="{Binding WindowTitle, Mode=OneWay}"

                 MinHeight="655"
                 MinWidth="530"

                 Height="655"
                 Width="530"

                 TitleCharacterCasing="Normal"
                 NonActiveWindowTitleBrush="Gray"
                 WindowTitleBrush="Gray"
                 BorderBrush="Gray"

                 ShowIconOnTitleBar="True"
                 Icon="../../Resources/Assets/Applications/Icon.png"

                 WindowStartupLocation="CenterScreen"
                 ResizeMode="CanResizeWithGrip"

                 Background="{DynamicResource MaterialDesignPaper}"
                 TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>

    <mah:MetroWindow.Resources>
        <converters:SplitUpperCaseWordsConverter x:Key="SplitCamelCaseConverter" />
    </mah:MetroWindow.Resources>

    <Grid margin:PanelExtensions.MarginForAllChildren="5">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBox Grid.Row="0" Grid.Column="1"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static locationResources:LocationResourceManager.PlaceNameHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding CurrentSearchResult.Name, Mode=TwoWay}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxNameLength}">
        </TextBox>

        <TextBox Grid.Row="1" Grid.Column="1"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static locationResources:LocationResourceManager.PlaceNumberHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding CurrentSearchResult.Address.HouseNumber, Mode=TwoWay, FallbackValue=''}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxNumberLength}">
        </TextBox>

        <TextBox Grid.Row="2" Grid.Column="1"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static locationResources:LocationResourceManager.PlaceStreetHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding CurrentSearchResult.Address.Road, Mode=TwoWay, FallbackValue=''}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxStreetLength}">
        </TextBox>

        <TextBox Grid.Row="3" Grid.Column="1"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static locationResources:LocationResourceManager.PlacePostalHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding CurrentSearchResult.Address.Postcode, Mode=TwoWay, FallbackValue=''}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxPostalLength}">
        </TextBox>

        <TextBox Grid.Row="4" Grid.Column="1"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static locationResources:LocationResourceManager.PlaceCityHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding CurrentSearchResult.Address.CityName, Mode=TwoWay, FallbackValue=''}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxCityLength}">
        </TextBox>

        <TextBox Grid.Row="5" Grid.Column="1"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static locationResources:LocationResourceManager.PlaceCountryHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding CurrentSearchResult.Address.Country, Mode=TwoWay, FallbackValue=''}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxCountryLength}">
        </TextBox>

        <ComboBox Grid.Row="6" Grid.Column="1"
                  Style="{StaticResource MaterialDesignFilledComboBox}"
                  materialDesign:HintAssist.Hint="{localisations:Tr {x:Static locationResources:LocationResourceManager.ComboBoxBaseMapHintAssist}}"
                  ItemsSource="{Binding KnownTileSources}"
                  SelectedItem="{Binding KnownTileSourceSelected}">

            <b:Interaction.Triggers>
                <b:EventTrigger EventName="SelectionChanged">
                    <b:InvokeCommandAction Command="{Binding UpdateTileSourceCommand}" CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource SplitCamelCaseConverter}}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>

        </ComboBox>

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.RowSpan="2"
                    margin:PanelExtensions.MarginForAllChildren="5"
                    Orientation="Vertical"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center">

            <Button materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Click="ButtonGoBack_OnClick">
                <Button.Content>
                    <materialDesign:PackIcon Kind="ArrowLeftBold" />
                </Button.Content>
            </Button>

            <Button materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperSecondaryButton}"
                    Content="{Binding ButtonCancelContent, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                    Click="ButtonCancel_OnClick">
            </Button>

        </StackPanel>

        <Border Grid.Row="7" Grid.Column="1" Grid.RowSpan="2"
                BorderBrush="{DynamicResource MaterialDesignBody}"
                BorderThickness="2"
                CornerRadius="5">

            <wpf:MapControl x:Name="MapControl" Map="{Binding Map}">
                <b:Interaction.Triggers>

                    <b:EventTrigger EventName="Loaded">
                        <b:InvokeCommandAction Command="{Binding MapControlLoadedCommand}"
                                               CommandParameter="{Binding ., ElementName=MapControl}">
                        </b:InvokeCommandAction>
                    </b:EventTrigger>

                </b:Interaction.Triggers>
            </wpf:MapControl>

        </Border>

        <StackPanel Grid.Row="7" Grid.Column="2" Grid.RowSpan="2"
                    margin:PanelExtensions.MarginForAllChildren="5"
                    Orientation="Vertical"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center">

            <Button materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Click="ButtonGoNext_OnClick">
                <Button.Content>
                    <materialDesign:PackIcon Kind="ArrowRightBold" />
                </Button.Content>
            </Button>

            <Button materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Content="{Binding ButtonValidContent, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                    Click="ButtonValid_OnClick">
            </Button>

        </StackPanel>

    </Grid>

</mah:MetroWindow>