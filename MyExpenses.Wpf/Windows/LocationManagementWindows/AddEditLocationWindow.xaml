<mah:MetroWindow x:Class="MyExpenses.Wpf.Windows.LocationManagementWindows.AddEditLocationWindow"
                 x:Name="RootWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:wpf="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
                 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                 xmlns:margin="clr-namespace:MyExpenses.Wpf.Utils.Margin;assembly=MyExpenses.Wpf.Utils"
                 xmlns:converters="clr-namespace:MyExpenses.Wpf.Converters"
                 xmlns:localisations="clr-namespace:MyExpenses.Wpf.Localisations"
                 xmlns:resx="clr-namespace:MyExpenses.Presentation.Resources.Resx.LocationResources;assembly=MyExpenses.Presentation"
                 xmlns:viewModel="clr-namespace:MyExpenses.Presentation.ViewModel;assembly=MyExpenses.Presentation"
                 xmlns:systems="clr-namespace:Domain.Models.Systems;assembly=MyExpenses.Domain"
                 xmlns:controlAssist="clr-namespace:MyExpenses.Wpf.ControlAssist"
                 xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                 mc:Ignorable="d"

                 TitleCharacterCasing="Normal"
                 NonActiveWindowTitleBrush="Gray"
                 WindowTitleBrush="Gray"
                 BorderBrush="Gray"

                 ShowIconOnTitleBar="True"
                 Icon="../../Resources/Assets/Applications/Icon.png"

                 WindowStartupLocation="CenterScreen"
                 ResizeMode="CanResizeWithGrip"

                 d:DesignHeight="656"
                 d:DesignWidth="780"
                 d:DataContext="{d:DesignInstance viewModel:LocationManagementViewModel}"

                 MinHeight="656"
                 MinWidth="780"

                 Height="656"
                 Width="780"

                 Background="{DynamicResource MaterialDesignPaper}"
                 TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <mah:MetroWindow.Style>
        <Style TargetType="{x:Type mah:MetroWindow}">
            <Setter Property="Title" Value="{localisations:Tr {x:Static resx:LocationResourceManager.AddLocationWindowTitle}}" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditLocation}" Value="True">
                    <Setter Property="Title" Value="{localisations:Tr {x:Static resx:LocationResourceManager.EditLocationWindowTitle}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Style>

    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>

    <mah:MetroWindow.Resources>
        <converters:SplitUpperCaseWordsConverter x:Key="SplitCamelCaseConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    </mah:MetroWindow.Resources>

    <Grid margin:PanelExtensions.MarginForAllChildren="5">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:LocationResourceManager.PlaceNameHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding SelectedPlaceViewModel.Name, FallbackValue='', Mode=TwoWay}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxNameLength}">
        </TextBox>

        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
              margin:PanelExtensions.MarginForAllChildren="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:LocationResourceManager.PlaceNumberHintAssist}}"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     Text="{Binding SelectedPlaceViewModel.Number, FallbackValue='', Mode=TwoWay}"
                     MaxLength="{x:Static systems:PlaceDomain.MaxNumberLength}">
            </TextBox>

            <CheckBox Grid.Column="1"
                      controlAssist:CheckboxAssist.ContentAlignment="Left"
                      IsThreeState="False"
                      IsChecked="{Binding SelectedPlaceViewModel.IsOpen, FallbackValue='', Mode=TwoWay}"
                      Content="{localisations:Tr {x:Static resx:LocationResourceManager.CheckBoxContentIsOpen}}"
                      materialDesign:CheckBoxAssist.CheckBoxSize="30">
            </CheckBox>

        </Grid>

        <TextBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:LocationResourceManager.PlaceStreetHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding SelectedPlaceViewModel.Street, FallbackValue='', Mode=TwoWay}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxStreetLength}">
        </TextBox>

        <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:LocationResourceManager.PlacePostalHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding SelectedPlaceViewModel.Postal, FallbackValue='', Mode=TwoWay}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxPostalLength}">
        </TextBox>

        <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:LocationResourceManager.PlaceCityHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding SelectedPlaceViewModel.City, FallbackValue='', Mode=TwoWay}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxCityLength}">
        </TextBox>

        <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:LocationResourceManager.PlaceCountryHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding SelectedPlaceViewModel.Country, FallbackValue='', Mode=TwoWay}"
                 MaxLength="{x:Static systems:PlaceDomain.MaxCountryLength}">
        </TextBox>

        <TextBox Grid.Row="6" Grid.Column="0"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:LocationResourceManager.PlaceLatitudeHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding SelectedPlaceViewModel.Latitude, FallbackValue='', Mode=TwoWay}"
                 controlAssist:NumericTextBoxAssist.IsNumericOnly="True">
        </TextBox>

        <StackPanel Grid.Row="6" Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    margin:PanelExtensions.MarginForAllChildren="5">

            <Button materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Content="{localisations:Tr {x:Static resx:LocationResourceManager.ButtonContentValidNewPoint}}"
                    Command="{Binding ValidTemporaryFeatureCommand}">
            </Button>

            <Button materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperLightButton}"
                    Content="{localisations:Tr {x:Static resx:LocationResourceManager.ButtonContentZoomToPoint}}"
                    Command="{Binding ZoomToPointsCommand}">
            </Button>

        </StackPanel>

        <TextBox Grid.Row="7" Grid.Column="0"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:LocationResourceManager.PlaceLongitudeHintAssist}}"
                 Style="{StaticResource MaterialDesignFilledTextBox}"
                 Text="{Binding SelectedPlaceViewModel.Longitude, FallbackValue='', Mode=TwoWay}"
                 controlAssist:NumericTextBoxAssist.IsNumericOnly="True">
        </TextBox>

        <Grid Grid.Row="8" Grid.Column="0"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              margin:PanelExtensions.MarginForAllChildren="5">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6"
                      Style="{StaticResource MaterialDesignFilledComboBox}"
                      materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:LocationResourceManager.ComboBoxBaseMapHintAssist}}"
                      ItemsSource="{Binding KnownTileSources}"
                      SelectedItem="{Binding KnownTileSourceSelected}">

                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding UpdateTileSourceCommand}" CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource SplitCamelCaseConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperLightButton}"
                    Content="{localisations:Tr {x:Static resx:LocationResourceManager.ButtonContentSearchByAddress}}"
                    Command="{Binding SearchByAddressCommand}">
            </Button>

            <Button Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="3"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperLightButton}"
                    Content="{localisations:Tr {x:Static resx:LocationResourceManager.ButtonContentSearchByCoordinate}}"
                    Command="{Binding SearchByCoordinateCommand}">
            </Button>

            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Content="{localisations:Tr {x:Static resx:LocationResourceManager.ButtonContentValid}}"
                    Visibility="{Binding IsEditLocation, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Click="ButtonValid_OnClick">
            </Button>

            <Button Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperSecondaryButton}"
                    Content="{localisations:Tr {x:Static resx:LocationResourceManager.ButtonContentDelete}}"
                    Visibility="{Binding IsEditLocation, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Click="ButtonDelete_OnClick">
            </Button>

            <Button Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="2"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperSecondaryButton}"
                    Content="{localisations:Tr {x:Static resx:LocationResourceManager.ButtonContentCancel}}"
                    Visibility="{Binding IsEditLocation, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding ElementName=RootWindow}">
            </Button>

            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Content="{localisations:Tr {x:Static resx:LocationResourceManager.ButtonContentValid}}"
                    Visibility="{Binding IsEditLocation, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    Click="ButtonValid_OnClick">
            </Button>

            <Button Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="3"
                    materialDesign:ButtonAssist.CornerRadius="5"
                    Style="{StaticResource MaterialDesignPaperSecondaryButton}"
                    Content="{localisations:Tr {x:Static resx:LocationResourceManager.ButtonContentCancel}}"
                    Visibility="{Binding IsEditLocation, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding ElementName=RootWindow}">
            </Button>

        </Grid>

        <Border Grid.Row="7" Grid.Column="1" Grid.RowSpan="2"
                BorderBrush="{DynamicResource MaterialDesignBody}"
                BorderThickness="2"
                CornerRadius="5">

            <wpf:MapControl x:Name="MapControl"
                            Map="{Binding Map}"
                            ContextMenuOpening="MapControl_OnContextMenuOpening">

                <b:Interaction.Triggers>

                    <b:EventTrigger EventName="Loaded">
                        <b:InvokeCommandAction Command="{Binding MapControlLoadedCommand}"
                                               CommandParameter="{Binding ., ElementName=MapControl}">
                        </b:InvokeCommandAction>
                    </b:EventTrigger>

                    <b:EventTrigger EventName="Info">
                        <b:InvokeCommandAction Command="{Binding MapInfoTemporaryFeatureCommand}"
                                               PassEventArgsToCommand="True">
                        </b:InvokeCommandAction>
                    </b:EventTrigger>

                </b:Interaction.Triggers>

                <wpf:MapControl.ContextMenu>

                    <ContextMenu>

                        <MenuItem
                            Header="{localisations:Tr {x:Static resx:LocationResourceManager.MenuItemHeaderGoogleEarthWeb}}"
                            Command="{Binding Path=PlacementTarget.(FrameworkElement.DataContext).(viewModel:LocationManagementViewModel.GoToGoogleEarthWebCommand), RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                        </MenuItem>

                        <MenuItem
                            Header="{localisations:Tr {x:Static resx:LocationResourceManager.MenuItemHeaderGoogleMaps}}"
                            Command="{Binding Path=PlacementTarget.(FrameworkElement.DataContext).(viewModel:LocationManagementViewModel.GoToGoogleMapsCommand), RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                        </MenuItem>

                        <MenuItem
                            Header="{localisations:Tr {x:Static resx:LocationResourceManager.MenuItemHeaderGoogleStreetView}}"
                            Command="{Binding Path=PlacementTarget.(FrameworkElement.DataContext).(viewModel:LocationManagementViewModel.GoToGoogleStreetViewCommand), RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                        </MenuItem>

                    </ContextMenu>

                </wpf:MapControl.ContextMenu>

            </wpf:MapControl>

        </Border>

    </Grid>

</mah:MetroWindow>