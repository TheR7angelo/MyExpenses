<mah:MetroWindow x:Class="MyExpenses.Wpf.Windows.CategoryTypeManagementWindow.AddEditCategoryTypeWindow"
                 x:Name="RootWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                 xmlns:margin="clr-namespace:MyExpenses.Wpf.Utils.Margin;assembly=MyExpenses.Wpf.Utils"
                 xmlns:localisations="clr-namespace:MyExpenses.Wpf.Localisations"
                 xmlns:resx="clr-namespace:MyExpenses.Presentation.Resources.Resx.ExpenseResources;assembly=MyExpenses.Presentation"
                 xmlns:expenses="clr-namespace:Domain.Models.Expenses;assembly=MyExpenses.Domain"
                 xmlns:viewModel="clr-namespace:MyExpenses.Presentation.ViewModel;assembly=MyExpenses.Presentation"
                 mc:Ignorable="d"

                 d:DesignHeight="250"
                 d:DesignWidth="400"
                 d:DataContext="{d:DesignInstance viewModel:CategoryTypeManagementViewModel}"

                 MinHeight="250"
                 MinWidth="400"
                 Height="250"
                 Width="400"

                 TitleCharacterCasing="Normal"
                 NonActiveWindowTitleBrush="Gray"
                 WindowTitleBrush="Gray"
                 BorderBrush="Gray"

                 ShowIconOnTitleBar="True"
                 Icon="../../Resources/Assets/Applications/Icon.png"

                 WindowStartupLocation="CenterScreen"
                 ResizeMode="CanResizeWithGrip"

                 Background="{DynamicResource MaterialDesignPaper}"
                 TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <mah:MetroWindow.Style>
        <Style TargetType="{x:Type mah:MetroWindow}">
            <Setter Property="Title" Value="{localisations:Tr {x:Static resx:ExpenseResourceManager.TitleWindowAddCategoryTypeName}}" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditCategoryType}" Value="True">
                    <Setter Property="Title" Value="{localisations:Tr {x:Static resx:ExpenseResourceManager.TitleWindowEditCategoryTypeName}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Style>

    <Grid margin:PanelExtensions.MarginForAllChildren="5">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0"
                 materialDesign:TextFieldAssist.HasClearButton="True"
                 materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:ExpenseResourceManager.TextBoxCategoryTypeNameHintAssist}}"
                 Text="{Binding CategoryTypeViewModel.Name, Mode=TwoWay}"
                 MaxLength="{x:Static expenses:CategoryTypeDomain.MaxNameLength}"
                 Style="{StaticResource MaterialDesignFilledTextBox}">
        </TextBox>

        <Grid Grid.Row="1" margin:PanelExtensions.MarginForAllChildren="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="ComboBoxColors" Grid.Column="0"
                      materialDesign:TextFieldAssist.HasClearButton="True"
                      materialDesign:HintAssist.Hint="{localisations:Tr {x:Static resx:ExpenseResourceManager.ComboBoxColorValueHintAssist}}"
                      ItemsSource="{Binding ColorViewModels}"
                      Style="{StaticResource MaterialDesignFilledComboBox}"
                      SelectedItem="{Binding CategoryTypeViewModel.Color, Mode=TwoWay}">

                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel margin:PanelExtensions.MarginForAllChildren="5"
                            Orientation="Horizontal">

                            <Ellipse Height="{Binding ActualHeight, ElementName=TextBlock}"
                                     Width="{Binding ActualHeight, ElementName=TextBlock}"
                                     StrokeThickness="1"
                                     Stroke="{DynamicResource MaterialDesignBody}"
                                     Fill="{Binding HexadecimalColorCode, Mode=OneWay}">
                            </Ellipse>

                            <TextBlock x:Name="TextBlock" Text="{Binding Name}" />

                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>

            </ComboBox>

            <Border Grid.Column="1"
                    Height="{Binding ActualHeight, UpdateSourceTrigger=PropertyChanged, ElementName=ComboBoxColors}"
                    Width="{Binding ActualHeight, UpdateSourceTrigger=PropertyChanged, ElementName=ComboBoxColors}"
                    BorderBrush="{DynamicResource MaterialDesignBody}"
                    BorderThickness="1.5"
                    Background="{Binding SelectedItem.HexadecimalColorCode, UpdateSourceTrigger=PropertyChanged, ElementName=ComboBoxColors}">
            </Border>

            <Button Grid.Column="2"
                    Style="{StaticResource MaterialDesignFloatingActionMiniDarkButton}"
                    Command="{Binding DataContext.ManageColorCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                    CommandParameter="{Binding ElementName=RootWindow}">

                <Button.Content>
                    <materialDesign:PackIcon Kind="PencilPlus" />
                </Button.Content>

            </Button>

        </Grid>

        <StackPanel Grid.Row="2"
                    margin:PanelExtensions.MarginForAllChildren="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center">

            <Button Content="{localisations:Tr {x:Static resx:ExpenseResourceManager.ButtonValidContentCategoryType}}"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Command="{Binding CreateOrUpdateCommand}"
                    CommandParameter="{Binding ElementName=RootWindow}">
            </Button>

            <Button Content="{localisations:Tr {x:Static resx:ExpenseResourceManager.ButtonDeleteContentCategoryType}}"
                    Style="{StaticResource MaterialDesignPaperDarkButton}"
                    Visibility="{Binding IsEditCategoryType, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Command="{Binding DeleteCommand}"
                    CommandParameter="{Binding ElementName=RootWindow}">
            </Button>

            <Button Content="{localisations:Tr {x:Static resx:ExpenseResourceManager.ButtonCancelContentCategoryType}}"
                    Style="{StaticResource MaterialDesignPaperSecondaryButton}"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding ElementName=RootWindow}">
            </Button>

        </StackPanel>

    </Grid>

</mah:MetroWindow>
