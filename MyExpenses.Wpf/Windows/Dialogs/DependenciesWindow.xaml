<mah:MetroWindow x:Class="MyExpenses.Wpf.Windows.Dialogs.DependenciesWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:local="clr-namespace:MyExpenses.Wpf.Windows.Dialogs"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:dependencies="clr-namespace:Domain.Models.Dependencies;assembly=MyExpenses.Domain"
                 mc:Ignorable="d"

                 Title="DependenciesWindow"

                 MinHeight="200"
                 MinWidth="425"
                 Height="200"
                 Width="425"

                 TitleCharacterCasing="Normal"
                 NonActiveWindowTitleBrush="Gray"
                 WindowTitleBrush="Gray"
                 BorderBrush="Gray"

                 ShowIconOnTitleBar="True"
                 Icon="../../../Resources/Assets/Applications/Icon.png"

                 WindowStartupLocation="CenterScreen"

                 Background="{DynamicResource MaterialDesignPaper}"
                 TextElement.Foreground="{DynamicResource MaterialDesignBody}"

                 DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Grid HorizontalAlignment="Center">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Source="{StaticResource TrashWarning}" Height="128" Width="128" />

        <Label Grid.Row="1" Content="Confirm deletion"
               HorizontalContentAlignment="Center"
               FontSize="15"
               FontWeight="Bold">
        </Label>

        <TextBlock Grid.Row="2"
                   Text="{Binding DeletingName, Mode=OneWay, StringFormat=Deleting this {0} will also remove these linked items}"
                   TextWrapping="Wrap">
        </TextBlock>

        <ScrollViewer Grid.Row="3"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">

            <ItemsControl ItemsSource="{Binding Dependencies}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type dependencies:DeletionDependency}">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="Icon" />

                            <TextBlock Grid.Column="1"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center">

                                <Run Text="{Binding Count}" BaselineAlignment="Center" />
                                <Run Text="{Binding Category}" BaselineAlignment="Center" />

                            </TextBlock>

                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <Button Content="Cancel" />
            <Button Content="Delete Everything" />
        </StackPanel>

    </Grid>

</mah:MetroWindow>