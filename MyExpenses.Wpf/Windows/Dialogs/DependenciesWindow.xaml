<mah:MetroWindow x:Class="MyExpenses.Wpf.Windows.Dialogs.DependenciesWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:local="clr-namespace:MyExpenses.Wpf.Windows.Dialogs"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:dependencies="clr-namespace:Domain.Models.Dependencies;assembly=MyExpenses.Domain"
                 xmlns:margin="clr-namespace:MyExpenses.Wpf.Utils.Margin;assembly=MyExpenses.Wpf.Utils"
                 xmlns:converters="clr-namespace:MyExpenses.Wpf.Converters"
                 xmlns:utils="clr-namespace:MyExpenses.Wpf.Utils;assembly=MyExpenses.Wpf.Utils"
                 mc:Ignorable="d"

                 Title="DependenciesWindow"

                 MinHeight="345"
                 MinWidth="345"
                 Height="345"
                 Width="345"

                 TitleCharacterCasing="Normal"
                 NonActiveWindowTitleBrush="Gray"
                 WindowTitleBrush="Gray"
                 BorderBrush="Gray"

                 ShowIconOnTitleBar="True"
                 Icon="../../../Resources/Assets/Applications/Icon.png"

                 WindowStartupLocation="CenterScreen"

                 Background="{DynamicResource MaterialDesignPaper}"
                 TextElement.Foreground="{DynamicResource MaterialDesignBody}"

                 DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <mah:MetroWindow.Resources>
        <converters:DependencyToIconConverter x:Key="DependencyToIconConverter" />
    </mah:MetroWindow.Resources>

    <Grid HorizontalAlignment="Center">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Image Grid.Row="0"
               Source="{StaticResource TrashWarning}"
               Height="96"
               Width="{Binding Height, RelativeSource={RelativeSource Self}}">
        </Image>

        <!-- TODO translate -->
        <Label Grid.Row="1" Content="Confirm deletion"
               HorizontalContentAlignment="Center"
               FontSize="15"
               FontWeight="Bold">
        </Label>

        <!-- TODO translate -->
        <TextBlock Grid.Row="2"
                   Text="{Binding DeletingName, Mode=OneWay, StringFormat=Deleting this {0} will also remove these linked items}"
                   TextWrapping="Wrap">
        </TextBlock>

        <ScrollViewer Grid.Row="3"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">

            <ItemsControl ItemsSource="{Binding Dependencies}"
                          utils:ItemsControlExtensions.UniformSize="True"
                          utils:ItemsControlExtensions.IsLiveUpdate="True">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type dependencies:DeletionDependency}">

                        <Border BorderBrush="{DynamicResource MaterialDesignBody}"
                                BorderThickness="1.3"
                                CornerRadius="3">

                            <Grid VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Source="{Binding Category, Mode=OneWay, Converter={StaticResource DependencyToIconConverter}}"
                                       Height="48"
                                       Width="{Binding Height, RelativeSource={RelativeSource Self}}"
                                       Stretch="Uniform">
                                </Image>

                                <TextBlock Grid.Column="1"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">

                                    <Run Text="{Binding Count}" BaselineAlignment="Center" />
                                    <!-- TODO translate -->
                                    <Run Text="{Binding Category}" BaselineAlignment="Center" />

                                </TextBlock>

                            </Grid>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    margin:PanelExtensions.MarginForAllChildren="5">

            <!-- TODO translate -->
            <Button Content="Cancel"
                    IsDefault="True"
                    Style="{StaticResource MaterialDesignPaperSecondaryDarkButton}"
                    Click="ButtonCancel_OnClick">
            </Button>

            <!-- TODO translate -->
            <Button Content="Delete Everything"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Click="ButtonConfirmation_OnClick">
            </Button>

        </StackPanel>

    </Grid>

</mah:MetroWindow>